# ---------------------------------------------------------------------------
# StudyMate HSC environment variables
# Copy to `.env` for local dev and set the same keys in Vercel project settings.
# ---------------------------------------------------------------------------

# Firebase Web SDK config (Project settings → Your apps → Web app)
# These are safe to expose to the browser (they identify, not authorise).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Anthropic / Claude API key — SERVER SIDE ONLY.
# Used by the /api serverless functions. Never prefix with VITE_ (that would
# ship the key to the browser). Set this in Vercel as an encrypted env var.
ANTHROPIC_API_KEY=

# Optional — override the Claude model used by all AI features without a code
# change. Defaults to the value baked into api/_lib.ts when unset. Handy if a
# model id is deprecated or you want to trial a newer/cheaper model.
# ANTHROPIC_MODEL=

# Owner / comp premium access. Comma-separated list of emails that ALWAYS get
# full premium (no subscription needed). Defaults to the owner's email if unset.
# OWNER_EMAILS is read server-side (the /api functions); VITE_OWNER_EMAILS is
# the browser copy used to unlock the UI — set both to the same value.
OWNER_EMAILS=liamtw042@gmail.com
VITE_OWNER_EMAILS=liamtw042@gmail.com

# ---------------------------------------------------------------------------
# Firebase Admin credential — SERVER SIDE ONLY.
# Enables real server-side enforcement of free-tier daily limits (the /api
# functions verify the caller's ID token and count usage in Firestore, so
# limits can't be reset by clearing browser storage). Without this, limits
# fall back to client-only (the app still works, but limits are bypassable).
#
# Provide EITHER the full service-account JSON as a single-line string:
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...", ...}
#
# ...OR the three fields individually (escape newlines in the key as \n):
# FIREBASE_PROJECT_ID=
# FIREBASE_CLIENT_EMAIL=
# FIREBASE_PRIVATE_KEY=
# Get these from Firebase console → Project settings → Service accounts →
# Generate new private key.
