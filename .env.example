# ---------------------------------------------------------------------------
# StudyMate HSC environment variables
# Copy to `.env` for local dev and set the same keys in Vercel project settings.
# ---------------------------------------------------------------------------

# Firebase Web SDK config (Project settings → Your apps → Web app)
# These are safe to expose to the browser (they identify, not authorise).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Anthropic / Claude API key — SERVER SIDE ONLY.
# Used by the /api serverless functions. Never prefix with VITE_ (that would
# ship the key to the browser). Set this in Vercel as an encrypted env var.
ANTHROPIC_API_KEY=
