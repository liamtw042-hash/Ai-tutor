rules_version = '2';

// StudyMate — Firebase Storage security rules.
// Student uploads (photos of work, worksheets, PDFs) live under
// users/{uid}/uploads/… and are strictly owner-only: no other user, signed in
// or not, can read or write another student's files. A 10 MB per-file cap and
// an image/PDF content-type check are enforced on write.
service firebase.storage {
  match /b/{bucket}/o {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/uploads/{fileName} {
      allow read: if isOwner(uid);
      allow delete: if isOwner(uid);
      allow write: if isOwner(uid)
        && request.resource.size < 10 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType == 'application/pdf'
        );
    }

    // Everything else is denied by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
