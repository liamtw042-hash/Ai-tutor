rules_version = '2';

// StudyMate HSC — Firestore security rules
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Users can only read and write their own profile and sub-collections.
    match /users/{uid} {
      allow read, write: if isOwner(uid);

      match /attempts/{id} {
        allow read, write: if isOwner(uid);
      }
      match /sessions/{id} {
        allow read, write: if isOwner(uid);
      }
      match /srs/{id} {
        allow read, write: if isOwner(uid);
      }
      match /days/{id} {
        allow read, write: if isOwner(uid);
      }
      match /decks/{deckId} {
        allow read, write: if isOwner(uid);
        match /cards/{cardId} {
          allow read, write: if isOwner(uid);
        }
      }
      match /exams/{id} {
        allow read, write: if isOwner(uid);
      }
      match /essays/{id} {
        allow read, write: if isOwner(uid);
      }
      match /plans/{id} {
        allow read, write: if isOwner(uid);
      }
      match /uploads/{id} {
        allow read, write: if isOwner(uid);
      }
      // Daily free-tier usage counters. Written only by the Admin SDK in the
      // serverless functions (which bypasses rules); the client may read its
      // own counters but never write them, so limits can't be reset client-side.
      match /usage/{day} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // Opt-in leaderboard: any signed-in user can read; each user may only
    // create/update/delete their own entry, with a sane shape.
    match /leaderboard/{uid} {
      allow read: if signedIn();
      allow create, update: if isOwner(uid)
        && request.resource.data.xp is number
        && request.resource.data.alias is string
        && request.resource.data.alias.size() <= 40;
      allow delete: if isOwner(uid);
    }

    // The shared question bank is world-readable to signed-in users and only
    // writable by trusted server/admin processes (never from the client).
    match /questions/{id} {
      allow read: if signedIn();
      allow write: if false;
    }
  }
}
